{
  "name": "@embersjs/core",
  "version": "0.2.0",
  "description": "Inner architecture for AI beings — drives, practices, and capabilities that shape how a being meets its experience.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ examples/",
    "lint:fix": "biome check --write src/ examples/",
    "format": "biome format --write src/ examples/",
    "typecheck": "tsc --noEmit",
    "check": "biome check src/ examples/ && tsc --noEmit && vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HaruHunab1320/embersjs.git"
  },
  "homepage": "https://github.com/HaruHunab1320/embersjs#readme",
  "bugs": {
    "url": "https://github.com/HaruHunab1320/embersjs/issues"
  },
  "keywords": [
    "ai",
    "inner-architecture",
    "drives",
    "practices",
    "capabilities",
    "metabolism"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
